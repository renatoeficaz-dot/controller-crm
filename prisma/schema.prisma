// Schema do CRM — Kanban de contatos + mensagens de WhatsApp
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Coluna do Kanban (ex.: Novo, Em conversa, Negociando, Fechado)
model Stage {
  id              String    @id @default(cuid())
  name            String
  color           String    @default("#64748b")
  order           Int       @default(0)
  autoResponsavel String?   // nome do usuário atribuído automaticamente quando um lead entra nesta etapa
  contacts        Contact[]
  usuarios        User[]    @relation("UserKanbans") // usuários (não-admin) que enxergam esta coluna
  agentesQueParam IaAgent[] @relation("StopAtStage") // agentes de IA configurados pra parar de responder a partir desta etapa
  createdAt       DateTime  @default(now())
}

// Contato / lead
model Contact {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  email     String?
  company   String?
  // Estado (UF) do lead identificado pela IA a partir do que ele conta na
  // conversa (ex.: "moro em Salvador") — complementa o DDD do telefone, que
  // nem sempre bate com onde a pessoa mora de fato.
  estado    String?
  notes     String?
  order     Int       @default(0)
  stage     Stage     @relation(fields: [stageId], references: [id])
  stageId   String
  messages  Message[]

  // Financeiro / cobrança
  valorCapital     Float?     // valor do empréstimo (base do cálculo dos honorários)
  pagamentoCapital DateTime?  // data da entrega do capital; 1ª cobrança = +1 dia
  responsavel      String?    // usuário responsável pela lead
  cicloAtual       Int        @default(1) // ciclo de empréstimo atual (renovações incrementam)
  tags             Tag[]      @relation("ContactTags")
  parcelas         Parcela[]
  tasks            Task[]
  lancamentos      Lancamento[]

  // Chatbot: sessão atual do lead num fluxo (null = nenhum bot em andamento)
  botFlowId String?
  botNodeId String?

  // Atendimento manual: enquanto true, a IA não responde esse lead (nem por
  // texto livre nem pelo chatbot em blocos) — o humano assumiu a conversa.
  // É ligado automaticamente ao mover o lead pra "Cravo", e pode ser
  // ligado/desligado manualmente pelo botão no chat/popup do lead.
  iaPausada Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Parcela diária de cobrança (10 por empréstimo)
model Parcela {
  id        String    @id @default(cuid())
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  number    Int                       // 1..10
  dueDate   DateTime
  amount    Float
  paid      Boolean   @default(false)
  paidAt    DateTime?
  ciclo     Int       @default(1)     // 1 = primeiro empréstimo, 2 = 1ª renovação, etc.
  // Valor realmente cobrado na baixa (pode ser diferente de `amount` quando o
  // cobrador escolhe baixar SEM o juro de atraso, pra aliviar o cliente).
  // null = ainda não paga.
  amountPago Float?
  task      Task?
}

// Tarefa do responsável pela lead (uma por parcela, na data do pagamento)
model Task {
  id        String    @id @default(cuid())
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  parcela   Parcela?  @relation(fields: [parcelaId], references: [id], onDelete: Cascade)
  parcelaId String?   @unique
  title     String
  notes     String?
  dueDate   DateTime
  done      Boolean   @default(false)
  tipo      TaskType? @relation(fields: [tipoId], references: [id], onDelete: SetNull)
  tipoId    String?
  createdAt DateTime  @default(now())
}

// Tipo de tarefa configurável (ex.: "Ligação", "Visita", "Cobrança extra")
model TaskType {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  tasks     Task[]
  createdAt DateTime @default(now())
}

// Mensagem pronta (modelo de texto/mídia/contato) para envio rápido aos contatos
model MessageTemplate {
  id            String   @id @default(cuid())
  title         String   // nome curto que aparece no seletor
  body          String   @default("") // texto da mensagem (ou legenda para mídia)
  mediaType     String?  // null/"text" | "image" | "audio" | "document" | "contact"
  mediaUrl      String?  // caminho do arquivo em /uploads (image/audio/document)
  mediaMimetype String?
  mediaFileName String?
  contactName   String?  // para tipo "contact"
  contactPhone  String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

// Fluxo de chatbot (editor visual por blocos). nodesJson/edgesJson guardam o
// grafo do React Flow serializado (array de nós/arestas em JSON).
model ChatbotFlow {
  id             String   @id @default(cuid())
  name           String
  active         Boolean  @default(false) // só um fluxo ativo por vez é usado no webhook
  triggerKeyword String?  // texto que a 1ª mensagem do contato deve conter pra iniciar o fluxo (vazio = qualquer 1ª msg)
  nodesJson      String   @default("[]")
  edgesJson      String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Configurações globais do sistema (linha única)
model Config {
  id                  String  @id @default("singleton")
  honorariosPct       Float   @default(30) // % cobrado sobre o Valor do capital
  multaPct            Float   @default(50) // % de multa aplicado à parcela vencida (juros por atraso)
  pagamentoHoraLimite String? // "HH:MM" — após esse horário, a parcela que vence hoje já conta como atrasada
  evolutionUrl        String? // URL do servidor Evolution (ex.: https://evo.exemplo.com)
  evolutionApiKey     String? // API Key global da Evolution

  // Meta diária: X% de todos os leads atualmente na etapa "Recebimento"
  // precisam pagar (dar baixa numa parcela) hoje.
  metaPctRecebimento Float @default(70)

  // Horário comercial da automação de responsável por etapa — fora dessa janela,
  // o lead entra na etapa mas NÃO é auto-atribuído (fica sem responsável até
  // alguém pegar manualmente ou até a próxima checagem dentro do horário).
  // Vazio = automação sempre ativa, sem restrição de horário.
  horarioComercialInicio String? // "HH:MM"
  horarioComercialFim    String? // "HH:MM"

  // IA: DeepInfra hospeda texto (Llama) e transcrição (Whisper), compartilhados por
  // todos os agentes. Cada agente pode escolher usar áudio da DeepInfra também, ou
  // de um provedor de voz dedicado (Fish Audio / ElevenLabs) usando o token abaixo.
  deepinfraApiKey  String? // token da conta em https://deepinfra.com/dash
  fishAudioApiKey  String? // token da conta em https://fish.audio
  elevenLabsApiKey String? // token da conta em https://elevenlabs.io

  // Conta de onde sai o dinheiro do capital liberado ao lead (débito automático
  // em Lançamentos ao entrar em "Recebimento"). Configurável pois pode mudar.
  contaLiberacao   Banco?  @relation("ContaLiberacao", fields: [contaLiberacaoId], references: [id], onDelete: SetNull)
  contaLiberacaoId String?

  // Conta onde entra o dinheiro das parcelas pagas pelo cobrador (crédito
  // automático em Lançamentos ao dar baixa numa parcela).
  contaRecebimento   Banco?  @relation("ContaRecebimento", fields: [contaRecebimentoId], references: [id], onDelete: SetNull)
  contaRecebimentoId String?
}

// Um "agente" de IA: prompt + modelos próprios. Cada número de WhatsApp escolhe
// qual agente atende (ou nenhum).
model IaAgent {
  id           String           @id @default(cuid())
  name         String
  prompt       String? // instruções de como esse agente deve atender
  textModel    String? // modelo de texto na DeepInfra (ex.: meta-llama/Meta-Llama-3.1-8B-Instruct)
  ttsProvider  String           @default("deepinfra") // "deepinfra" | "fishaudio" | "elevenlabs"
  ttsModel     String? // modelo de áudio na DeepInfra (ex.: ResembleAI/chatterbox-turbo) — só quando ttsProvider = deepinfra
  ttsVoice     String? // voz/referência: nome da voz (Kokoro), reference_id (Fish Audio) ou voice_id (ElevenLabs)
  modoResposta String           @default("espelho") // "espelho" (áudio→áudio, texto→texto) | "texto" | "audio"

  // Funções que a IA pode chamar sozinha durante a conversa (function calling)
  toolSendContact  Boolean @default(false) // pode enviar um contato (vCard) configurado abaixo
  toolContactName  String? // nome do contato que a função "enviar contato" manda
  toolContactPhone String? // telefone do contato que a função "enviar contato" manda
  toolSendTemplate Boolean @default(false) // pode enviar uma das mensagens prontas (inclui áudios pré-gravados)
  toolMoveStage    Boolean @default(false) // pode mover o lead para outra etapa do funil

  // A partir desta etapa (e qualquer etapa depois dela na ordem do funil), a IA
  // para de responder — o atendimento passa a ser 100% humano. null = nunca para.
  stopAtStage   Stage?  @relation("StopAtStage", fields: [stopAtStageId], references: [id], onDelete: SetNull)
  stopAtStageId String?

  numeros      WhatsappNumber[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// Usuário do sistema (cadastro em Configurações) — também faz login no app.
model User {
  id              String           @id @default(cuid())
  name            String
  login           String           @unique
  passwordHash    String
  role            String           @default("vendedor") // admin | vendedor | cobrador
  verTodosLeads   Boolean          @default(false)       // false = só leads onde é responsável
  numeros         WhatsappNumber[] @relation("NumeroResponsavel")  // números atribuídos (ownership)
  numerosVisiveis WhatsappNumber[] @relation("NumeroVisibilidade") // WhatsApp cujas mensagens pode ver
  kanbansVisiveis Stage[]          @relation("UserKanbans")        // colunas do funil que pode ver
  createdAt       DateTime         @default(now())
}

// Número de WhatsApp conectado (uma instância da Evolution), atribuível a um usuário
model WhatsappNumber {
  id                 String   @id @default(cuid())
  label              String   // nome amigável (ex.: "Comercial 1")
  number             String   // número (ex.: 5511999998888)
  instance           String   // nome da instância na Evolution
  user               User?    @relation("NumeroResponsavel", fields: [userId], references: [id], onDelete: SetNull)
  userId             String?
  usuariosVisualizam User[]   @relation("NumeroVisibilidade") // usuários que podem ver as mensagens deste número
  agent              IaAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentId            String?  // agente de IA que atende neste número (null = IA desligada aqui)

  // Cobrança automática: estados (UF) que este número atende, pelo DDD do
  // cliente (ex.: "SP,MG"), e a mensagem enviada diariamente antes do horário
  // limite de pagamento pra quem está em "Recebimento".
  estadosCobranca    String?
  mensagemCobranca   String?

  // Número padrão (só um por vez) — destacado na lista.
  padrao         Boolean   @default(false)
  // Rastreamento de conexão: usado pra mostrar "Conectado em ..." /
  // "Desconectado em ..." e alimentar o histórico (ConexaoLog).
  ultimoEstado   String?   // último estado conhecido na Evolution ("open" | "close" | "connecting")
  conectadoEm    DateTime?
  desconectadoEm DateTime?
  logs           ConexaoLog[]

  createdAt          DateTime @default(now())
}

// Histórico de conexão/desconexão de cada número (pra tela "Ver histórico de conexões").
model ConexaoLog {
  id        String         @id @default(cuid())
  numero    WhatsappNumber @relation(fields: [numeroId], references: [id], onDelete: Cascade)
  numeroId  String
  evento    String         // "conectado" | "desconectado"
  createdAt DateTime       @default(now())
}

// Log de lembretes de cobrança já enviados (evita mandar 2x no mesmo dia).
model LembreteCobrancaLog {
  id        String   @id @default(cuid())
  contactId String
  dia       DateTime // meia-noite UTC do dia do lembrete
  createdAt DateTime @default(now())

  @@unique([contactId, dia])
}

// Histórico de atribuições automáticas de responsável (uma linha por vez que
// a automação por etapa realmente atribuiu alguém a um lead).
model AtribuicaoLog {
  id          String   @id @default(cuid())
  contactId   String
  contactName String   // snapshot — continua legível mesmo se o lead for excluído depois
  stageName   String
  responsavel String
  createdAt   DateTime @default(now())
}

// Etiqueta (tag) atribuível a leads
model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  color    String    @default("#6366f1") // cor do badge
  contacts Contact[] @relation("ContactTags")
  rules    AutoTagRule[]
  createdAt DateTime @default(now())
}

// Regra de auto-tag: se a 1ª mensagem do cliente contém o texto, atribui a tag.
model AutoTagRule {
  id        String @id @default(cuid())
  match     String // texto que a 1ª mensagem deve conter (case-insensitive)
  tag       Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String
  createdAt DateTime @default(now())
}

// Categoria de lançamento (entrada ou saída)
model LancamentoCategoria {
  id          String       @id @default(cuid())
  name        String
  type        String       // "entrada" | "saida"
  lancamentos Lancamento[]
  createdAt   DateTime     @default(now())
}

// Banco / conta financeira
model Banco {
  id              String       @id @default(cuid())
  name            String
  lancamentos     Lancamento[]
  configsLibera   Config[]     @relation("ContaLiberacao")
  configsRecebe   Config[]     @relation("ContaRecebimento")
  createdAt       DateTime     @default(now())
}

// Lançamento financeiro (entrada ou saída). Pagamentos de parcelas geram lançamentos automáticos.
model Lancamento {
  id           String              @id @default(cuid())
  type         String              // "entrada" | "saida"
  amount       Float
  description  String?
  date         DateTime            @default(now())
  categoria    LancamentoCategoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  categoriaId  String?
  banco        Banco?              @relation(fields: [bancoId], references: [id], onDelete: SetNull)
  bancoId      String?
  contact      Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId    String?
  parcelaId    String?             // referência à parcela (se gerado automaticamente)
  createdAt    DateTime            @default(now())
}

// Mensagem trocada com o contato pelo WhatsApp (Evolution API)
model Message {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  body      String   @default("") // texto / legenda
  kind      String   @default("text") // text | audio | image | document
  mediaUrl  String?  // caminho do arquivo (áudio/imagem/anexo)
  mimeType  String?
  fileName  String?
  fromMe    Boolean  @default(true) // true = enviada por nós, false = recebida do cliente
  status    String   @default("sent")
  instance  String?  // instância da Evolution que originou/enviou (controle de visibilidade por usuário)
  readAt    DateTime? // null = não visualizada pelo operador
  createdAt DateTime @default(now())
}

